# ── 应用配置 ──────────────────────────────────────
APP_ENV=development
DEBUG=false

# ── API 配置 ──────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── LLM 配置 ──────────────────────────────────────
# 支持 OpenAI 兼容的提供商（OpenAI、DeepSeek、Azure OpenAI 等）
OPENAI_API_KEY=your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# ── ArcGIS 配置 ───────────────────────────────────
# 如果 arcpy 不在默认 Python 路径中，指定其位置
# ARCPY_PATH=C:/Program Files/ArcGIS/Pro/bin/Python/envs/arcgispro-py3/Lib/site-packages

# ── GIS 数据路径 ──────────────────────────────────
GIS_DATA_PATH=./data

# ── Docker 配置 ──────────────────────────────────
COMPOSE_PROJECT_NAME=arcgis-agent
